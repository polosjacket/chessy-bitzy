# ─── Node.js ────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ─── Build Output ────────────────────────────────────────────
dist/
dist-ssr/
build/
out/

# ─── Vite ────────────────────────────────────────────────────
.vite/
vite.config.js.timestamp-*

# ─── Environment Variables ───────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

