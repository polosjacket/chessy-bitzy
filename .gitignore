.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Logs ────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ─── Testing ─────────────────────────────────────────────────
coverage/
.nyc_output/
test-results/
playwright-report/

# ─── Cache ───────────────────────────────────────────────────
.cache/
.eslintcache
.stylelintcache
.parcel-cache/

# ─── Package Manager Lock Files (keep only one) ──────────────
# Uncomment one to keep it tracked:
# yarn.lock
# pnpm-lock.yaml
# Keep package-lock.json tracked (default for npm)

# ─── 3D Assets (large binary files) ─────────────────────────
# public/models/*.glb     ← Uncomment if using Git LFS instead
# public/textures/*.png   ← Uncomment if using Git LFS instead

# ─── Temporary / Scratch ─────────────────────────────────────
tmp/
temp/
scratch/
*.tmp
*.bak
*.orig

# ─── Security ────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
secrets.json
